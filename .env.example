# Logging Configuration
LOG_PATH=./logs
LOG_LEVEL=info

# Data Store Configuration
STORE_PATH=./data
STORE_TYPE=json

# LM Studio Configuration
LM_STUDIO_ENDPOINT=http://localhost:1234/v1

# Application Configuration
APP_NAME=LogSummarizer
VERSION=0.1.0

# Processing Configuration
BATCH_SIZE=10
MAX_RETRIES=3

# Environment
ENV=development

# Feature Flags
ENABLE_STREAMING=true
ENABLE_CACHE=true

# Security
ALLOW_CORS=true
CORS_ORIGINS=*