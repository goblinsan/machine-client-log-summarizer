# Multi-Agent Log Summarizer Configuration
# Copy this file to .env and customize as needed

# Logging Configuration
LOG_PATH=./logs              # Directory for log files
LOG_LEVEL=info               # One of: debug, info, warn, error
TIMEOUT=30000                # Request timeout in milliseconds

# Storage Configuration
STORE_PATH=./data            # Directory for data storage
STORE_TYPE=json              # One of: json, sqlite, mongodb

# LM Studio Endpoint
LM_STUDIO_ENDPOINT=http://localhost:1234/v1  # Local LLM endpoint

# Application Configuration
APP_NAME=Multi-Agent Log Summarizer
VERSION=1.0.0

# Processing Configuration
BATCH_SIZE=10                # Number of logs to process per batch
MAX_RETRIES=3                # Maximum retry attempts for failed operations

# Environment
ENV=development              # One of: development, production, test

# Feature Flags
ENABLE_STREAMING=true        # Enable streaming responses
ENABLE_CACHE=true            # Enable caching

# Security Configuration
ALLOW_CORS=true              # Allow CORS requests
CORS_ORIGINS=*               # Comma-separated list of allowed origins