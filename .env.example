LOG_PATH=/var/log/machine-client
STORE_PATH=/var/store/machine-client
LM_STUDIO_ENDPOINT=http://localhost:1234/v1

# Optional: Override any of the above by setting these environment variables
# LOG_PATH=/custom/logs
# STORE_PATH=/custom/store
# LM_STUDIO_ENDPOINT=http://custom:1234/v1
# Logging
LOG_PATH=./logs
LOG_LEVEL=info
TIMEOUT=30000

# Data Store
STORE_PATH=./data
STORE_TYPE=json

# LM Studio Endpoint
LM_STUDIO_ENDPOINT=http://localhost:1234/v1

# Application
APP_NAME=LogSummarizer
VERSION=0.1.0

# Processing
BATCH_SIZE=10
MAX_RETRIES=3

# Environment
ENV=development

# Features
ENABLE_STREAMING=true
ENABLE_CACHE=true

# Security
ALLOW_CORS=true
CORS_ORIGINS=*
