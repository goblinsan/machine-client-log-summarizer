# Multi-Agent Log Summarizer Configuration
# Copy this file to .env and modify values as needed

# Logging Configuration
LOG_PATH=logs
LOG_LEVEL=info
TIMEOUT=30000

# Store Configuration
STORE_PATH=./store
STORE_TYPE=json

# LM Studio Endpoint
LM_STUDIO_ENDPOINT=http://localhost:1234/v1

# Application Configuration
APP_NAME=Multi-Agent Log Summarizer
VERSION=1.0.0

# Processing Configuration
BATCH_SIZE=10
MAX_RETRIES=3

# Environment
ENV=development

# Feature Flags
ENABLE_STREAMING=true
ENABLE_CACHE=true

# Security Configuration
ALLOW_CORS=true
CORS_ORIGINS=*