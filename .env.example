# Multi-Agent Log Summarizer Configuration
# Copy this file to .env and customize as needed

# Log Configuration
LOG_PATH=logs
LOG_STORE=file

# LM Studio Configuration
LM_STUDIO_ENDPOINT=http://localhost:1234/v1

# Model Configuration
MODEL=mistralai/Mistral-7B-Instruct-v0.1

# Generation Configuration
TEMPERATURE=0.7
MAX_TOKENS=4096

# Feature Flags
ENABLE_SECURITY=true
ENABLE_QA=true
LOG_LEVEL=info
TIMEOUT=30000

# Storage Configuration
STORE_PATH=./data
STORE_TYPE=json

# LM Studio Endpoint
LM_STUDIO_ENDPOINT=http://localhost:1234/v1

# Application Configuration
APP_NAME=Multi-Agent Log Summarizer
VERSION=1.0.0

# Processing Configuration
BATCH_SIZE=10
MAX_RETRIES=3

# Environment Mode
ENV=development

# Feature Flags
ENABLE_STREAMING=true
ENABLE_CACHE=true

# Security Configuration
ALLOW_CORS=true
CORS_ORIGINS=*
