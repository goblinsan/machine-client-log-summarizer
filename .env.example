# Multi-Agent Log Summarizer Environment Configuration
# Copy this file to .env and fill in your values

# Logging Configuration
LOG_PATH=./logs
LOG_LEVEL=info
TIMEOUT=30000

# Storage Configuration
STORE_PATH=./data
STORE_TYPE=json

# LM Studio Endpoint
LM_STUDIO_ENDPOINT=http://localhost:1234/v1

# Application Configuration
APP_NAME=Multi-Agent Log Summarizer
VERSION=1.0.0

# Processing Configuration
BATCH_SIZE=10
MAX_RETRIES=3

# Environment Mode
ENV=development

# Feature Flags
ENABLE_STREAMING=true
ENABLE_CACHE=true

# Security Configuration
ALLOW_CORS=true
CORS_ORIGINS=*